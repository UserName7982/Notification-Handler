<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            prefWidth="1300"
            prefHeight="750"
            style="-fx-background-color: #0f172a;">

    <!-- ================= TOP HEADER ================= -->
    <top>
        <HBox spacing="15"
              alignment="CENTER_LEFT"
              style="-fx-background-color: #111827;
                     -fx-border-color: #1f2937;
                     -fx-border-width: 0 0 1 0;">

            <padding>
                <Insets top="18" right="25" bottom="18" left="25"/>
            </padding>

            <Label text="AI Notification Manager"
                   style="-fx-text-fill: white;
                          -fx-font-size: 24px;
                          -fx-font-weight: bold;" />

            <Region HBox.hgrow="ALWAYS"/>

            <TextField promptText="Search notifications..."
                       prefWidth="280"
                       style="-fx-background-color: #1e293b;
                              -fx-text-fill: white;
                              -fx-prompt-text-fill: #94a3b8;
                              -fx-background-radius: 10;
                              -fx-border-radius: 10;
                              -fx-padding: 10;" />

            <Button text="Refresh"
                    style="-fx-background-color: #2563eb;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-background-radius: 10;
                           -fx-padding: 10 18;" />
        </HBox>
    </top>

    <!-- ================= MAIN CONTENT ================= -->
    <center>

        <HBox spacing="18"
              BorderPane.alignment="CENTER">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- ================================================= -->
            <!-- SECTION 1 : VIEW NOTIFICATIONS -->
            <!-- ================================================= -->

            <VBox spacing="15"
                  prefWidth="400"
                  style="-fx-background-color: #111827;
                         -fx-background-radius: 18;
                         -fx-border-radius: 18;
                         -fx-border-color: #1f2937;">

                <padding>
                    <Insets top="18" right="18" bottom="18" left="18"/>
                </padding>

                <!-- Title -->
                <HBox alignment="CENTER_LEFT" spacing="10">

                    <Label text="Notifications"
                           style="-fx-text-fill: white;
                                  -fx-font-size: 20px;
                                  -fx-font-weight: bold;" />

                    <Region HBox.hgrow="ALWAYS"/>

                    <Label text="12"
                           style="-fx-background-color: #2563eb;
                                  -fx-text-fill: white;
                                  -fx-padding: 4 10;
                                  -fx-background-radius: 20;" />
                </HBox>

                <!-- Description -->
                <Label text="Simple popup notifications generated by AI or server events."
                       wrapText="true"
                       style="-fx-text-fill: #94a3b8;
                              -fx-font-size: 13px;" />

                <!-- Notification List -->
                <ScrollPane fitToWidth="true"
                            VBox.vgrow="ALWAYS"
                            style="-fx-background: transparent;
                                   -fx-background-color: transparent;">

                    <content>
                        <VBox spacing="12">

                            <!-- Notification Card -->
                            <VBox spacing="6"
                                  style="-fx-background-color: #1e293b;
                                         -fx-background-radius: 14;
                                         -fx-padding: 14;">

                                <Label text="New Email Generated"
                                       style="-fx-text-fill: white;
                                              -fx-font-size: 15px;
                                              -fx-font-weight: bold;" />

                                <Label text="AI generated a professional email draft."
                                       wrapText="true"
                                       style="-fx-text-fill: #cbd5e1;" />

                                <Label text="2 min ago"
                                       style="-fx-text-fill: #64748b;
                                              -fx-font-size: 11px;" />
                            </VBox>

                            <VBox spacing="6"
                                  style="-fx-background-color: #1e293b;
                                         -fx-background-radius: 14;
                                         -fx-padding: 14;">

                                <Label text="Task Completed"
                                       style="-fx-text-fill: white;
                                              -fx-font-size: 15px;
                                              -fx-font-weight: bold;" />

                                <Label text="Document summarization completed successfully."
                                       wrapText="true"
                                       style="-fx-text-fill: #cbd5e1;" />

                                <Label text="5 min ago"
                                       style="-fx-text-fill: #64748b;
                                              -fx-font-size: 11px;" />
                            </VBox>

                        </VBox>
                    </content>
                </ScrollPane>

            </VBox>

            <!-- ================================================= -->
            <!-- SECTION 2 : ACTION REQUIRED NOTIFICATIONS -->
            <!-- ================================================= -->

            <VBox spacing="15"
                  prefWidth="430"
                  style="-fx-background-color: #111827;
                         -fx-background-radius: 18;
                         -fx-border-radius: 18;
                         -fx-border-color: #1f2937;">

                <padding>
                    <Insets top="18" right="18" bottom="18" left="18"/>
                </padding>

                <HBox alignment="CENTER_LEFT" spacing="10">

                    <Label text="Action Required"
                           style="-fx-text-fill: white;
                                  -fx-font-size: 20px;
                                  -fx-font-weight: bold;" />

                    <Region HBox.hgrow="ALWAYS"/>

                    <Label text="5"
                           style="-fx-background-color: #dc2626;
                                  -fx-text-fill: white;
                                  -fx-padding: 4 10;
                                  -fx-background-radius: 20;" />
                </HBox>

                <Label text="Notifications that require user interaction or confirmation."
                       wrapText="true"
                       style="-fx-text-fill: #94a3b8;
                              -fx-font-size: 13px;" />

                <ScrollPane fitToWidth="true"
                            VBox.vgrow="ALWAYS"
                            style="-fx-background: transparent;
                                   -fx-background-color: transparent;">

                    <content>
                        <VBox spacing="14">

                            <!-- Action Card -->
                            <VBox spacing="10"
                                  style="-fx-background-color: #1e293b;
                                         -fx-background-radius: 14;
                                         -fx-padding: 16;">

                                <Label text="Approve Deployment"
                                       style="-fx-text-fill: white;
                                              -fx-font-size: 16px;
                                              -fx-font-weight: bold;" />

                                <Label text="AI deployment pipeline is ready for production approval."
                                       wrapText="true"
                                       style="-fx-text-fill: #cbd5e1;" />

                                <HBox spacing="10">

                                    <Button text="Approve"
                                            style="-fx-background-color: #16a34a;
                                                   -fx-text-fill: white;
                                                   -fx-font-weight: bold;
                                                   -fx-background-radius: 10;" />

                                    <Button text="Reject"
                                            style="-fx-background-color: #dc2626;
                                                   -fx-text-fill: white;
                                                   -fx-font-weight: bold;
                                                   -fx-background-radius: 10;" />
                                </HBox>

                            </VBox>

                            <VBox spacing="10"
                                  style="-fx-background-color: #1e293b;
                                         -fx-background-radius: 14;
                                         -fx-padding: 16;">

                                <Label text="Database Permission"
                                       style="-fx-text-fill: white;
                                              -fx-font-size: 16px;
                                              -fx-font-weight: bold;" />

                                <Label text="Server requests access to modify notification schema."
                                       wrapText="true"
                                       style="-fx-text-fill: #cbd5e1;" />

                                <HBox spacing="10">

                                    <Button text="Allow"
                                            style="-fx-background-color: #2563eb;
                                                   -fx-text-fill: white;
                                                   -fx-font-weight: bold;
                                                   -fx-background-radius: 10;" />

                                    <Button text="Deny"
                                            style="-fx-background-color: #475569;
                                                   -fx-text-fill: white;
                                                   -fx-font-weight: bold;
                                                   -fx-background-radius: 10;" />
                                </HBox>

                            </VBox>

                        </VBox>
                    </content>
                </ScrollPane>

            </VBox>

            <!-- ================================================= -->
            <!-- SECTION 3 : WAITING / PROCESSING NOTIFICATIONS -->
            <!-- ================================================= -->

            <VBox spacing="15"
                  prefWidth="400"
                  style="-fx-background-color: #111827;
                         -fx-background-radius: 18;
                         -fx-border-radius: 18;
                         -fx-border-color: #1f2937;">

                <padding>
                    <Insets top="18" right="18" bottom="18" left="18"/>
                </padding>

                <HBox alignment="CENTER_LEFT" spacing="10">

                    <Label text="Waiting Responses"
                           style="-fx-text-fill: white;
                                  -fx-font-size: 20px;
                                  -fx-font-weight: bold;" />

                    <Region HBox.hgrow="ALWAYS"/>

                    <ProgressIndicator progress="-1"
                                       prefWidth="28"
                                       prefHeight="28" />
                </HBox>

                <Label text="Tasks currently processing on server or waiting for response."
                       wrapText="true"
                       style="-fx-text-fill: #94a3b8;
                              -fx-font-size: 13px;" />

                <ScrollPane fitToWidth="true"
                            VBox.vgrow="ALWAYS"
                            style="-fx-background: transparent;
                                   -fx-background-color: transparent;">

                    <content>
                        <VBox spacing="14">

                            <!-- Waiting Card -->
                            <VBox spacing="10"
                                  style="-fx-background-color: #1e293b;
                                         -fx-background-radius: 14;
                                         -fx-padding: 16;">

                                <Label text="Generating AI Summary"
                                       style="-fx-text-fill: white;
                                              -fx-font-size: 15px;
                                              -fx-font-weight: bold;" />

                                <ProgressBar progress="0.65"
                                             prefWidth="320" />

                                <Label text="Server is generating final report..."
                                       style="-fx-text-fill: #cbd5e1;" />

                                <Label text="Estimated Time: 20 sec"
                                       style="-fx-text-fill: #64748b;
                                              -fx-font-size: 11px;" />

                            </VBox>

                            <VBox spacing="10"
                                  style="-fx-background-color: #1e293b;
                                         -fx-background-radius: 14;
                                         -fx-padding: 16;">

                                <Label text="Waiting for API Response"
                                       style="-fx-text-fill: white;
                                              -fx-font-size: 15px;
                                              -fx-font-weight: bold;" />

                                <ProgressIndicator progress="-1"
                                                   prefWidth="45"
                                                   prefHeight="45" />

                                <Label text="Notification service is waiting for backend response."
                                       wrapText="true"
                                       style="-fx-text-fill: #cbd5e1;" />

                                <Label text="Running..."
                                       style="-fx-text-fill: #f59e0b;
                                              -fx-font-size: 12px;
                                              -fx-font-weight: bold;" />

                            </VBox>

                        </VBox>
                    </content>
                </ScrollPane>

            </VBox>

        </HBox>

    </center>

</BorderPane>